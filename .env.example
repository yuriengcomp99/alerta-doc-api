# App
NODE_ENV=development
PORT=3000

# Postgres
POSTGRES_USER=alerta
POSTGRES_PASSWORD=alerta_secret
POSTGRES_DB=alerta_doc
POSTGRES_PORT=5432

# Prisma
DATABASE_URL=postgresql://alerta:alerta_secret@localhost:5432/alerta_doc?schema=public

# RabbitMQ (só infra — publicação feita pelo cron job em outro repositório)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Nginx
NGINX_HTTP_PORT=80

# Uploads (documentos)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Auth — tokens opacos persistidos no banco (access + refresh)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d